{
  "name": "pi-cy",
  "private": true,
  "version": "0.1.0",
  "description": "PI-CY - AI Coding Assistant powered by Xiaomi MiMo",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx src/server/index.ts",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev\"",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "tauri": "tauri",
    "start": "node dist-server/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\""
  },
  "author": "PI-CY Community",
  "license": "Apache-2.0",
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.12",
    "monaco-editor": "^0.55.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ws": "^8.21.0",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@tailwindcss/vite": "^4.1.7",
    "@tauri-apps/cli": "^2",
    "@types/node": "^22.19.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.2.0",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.1.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.7",
    "tsx": "^4.22.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.33.0",
    "vite": "^6.3.5"
  }
}
